{
  "name": "@codecrush/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node -r ./dist/tracing.js dist/main.js",
    "start:nest": "nest start",
    "dev": "nest start --watch",
    "test": "jest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:backfill-prompts": "tsx src/db/backfill-prompt-contracts.ts",
    "db:backfill-applications": "tsx src/db/backfill-applications.ts",
    "test:db": "cross-env RUN_DB_TESTS=1 jest test/prompts.migration.spec.ts",
    "db:seed": "tsx src/db/seed.ts",
    "observability:verify": "node scripts/verify-observability.mjs"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.1",
    "@codecrush/contracts": "workspace:^",
    "@codecrush/otel": "workspace:^",
    "@codecrush/otel-conventions": "workspace:^",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "nestjs-zod": "^5.4.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "pg-boss": "^12.25.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.4.2",
    "supertest": "^7.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
